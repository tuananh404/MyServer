# ==========================================================================
# ENVIRONMENTAL VARIABLES CONFIGURATION
# Copy this file to '.env' and fill in your values.
# Do NOT check the actual '.env' file into source control.
# ==========================================================================

# 1. Supabase Project Configuration
# Found in: Supabase Project Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
# It is recommended to use the service role key to bypass RLS policies for admin tasks.
# (If using Anon Key, ensure RLS is disabled or appropriate select/insert/delete permissions are set)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 2. Administrative Control Access
# Secret token to protect the API routes and log in to the Dashboard panel
ADMIN_PASSWORD=your_strong_admin_password_here

# Optional comma-separated browser origins. Native clients are unaffected.
ALLOWED_ORIGINS=https://your-project.vercel.app

# 3. Local Development Configuration
PORT=3000
NODE_ENV=development
